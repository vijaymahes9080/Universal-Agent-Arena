# =============================================================================
# Universal Agent Arena — .gitignore
# =============================================================================

# ──────────────────────────────────────────────
# Python
# ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
*.so

# Virtual environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/
.python-version

# pytest / testing
.pytest_cache/
.cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
nosetests.xml
*.cover
*.log

# mypy / pyright
.mypy_cache/
.dmypy.json
dmypy.json
.pyright/

# ──────────────────────────────────────────────
# SQLite Databases
# ──────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ──────────────────────────────────────────────
# Node / Frontend
# ──────────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# Vite / Build output
frontend/dist/
frontend/dist-ssr/
frontend/.vite/

# TypeScript build info
*.tsbuildinfo
tsconfig.tsbuildinfo

# npm / yarn / pnpm
package-lock.json.bak
yarn-error.log
.pnpm-store/

# ──────────────────────────────────────────────
# Environment & Secrets
# ──────────────────────────────────────────────
.env
.env.local
.env.development
.env.development.local
.env.test.local
.env.production
.env.production.local
*.pem
*.key
secrets.json
config.local.*

# ──────────────────────────────────────────────
# IDE & Editor
# ──────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.history/
*.code-workspace

# Vim
*.swp
*.swo
*~

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# ──────────────────────────────────────────────
# Logs
# ──────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
pip-log.txt
pip-delete-this-directory.txt

# ──────────────────────────────────────────────
# Docker (future)
# ──────────────────────────────────────────────
.dockerignore
docker-compose.override.yml

# ──────────────────────────────────────────────
# Misc
# ──────────────────────────────────────────────
*.bak
*.tmp
*.temp
*.DS_Store
.vercel
.netlify
